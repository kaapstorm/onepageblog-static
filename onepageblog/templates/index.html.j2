<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ config.site_title }}</title>
  <link rel="alternate" type="application/rss+xml"
        title="{{ config.site_title }} RSS Feed"
        href="{{ config.base_url }}feed.xml">
  <link rel="stylesheet" href="{{ config.base_url }}fonts.css">
  <link rel="stylesheet" href="{{ config.base_url }}default.css">
  <script src="{{ config.base_url }}htmx.min.js"></script>
  <script defer src="{{ config.base_url }}alpinejs.min.js"></script>
</head>
<body>
  <div class="outer">
    <header>
      <h1>{{ config.site_title }}</h1>
    </header>
    <nav>
      <a href="{{ config.base_url }}feed.xml">RSS Feed</a>
    </nav>
    <main>
      {% for post in posts %}
      <div class="post" x-data="{ open: false }">
        <div class="post-header"
             hx-get="{{ config.base_url }}{{ post.slug }}/ajax.html"
             hx-target="next .post-body"
             hx-swap="innerHTML"
             hx-trigger="click once"
             hx-indicator="#{{ post.slug }}-loading"
             role="button"
             tabindex="0"
             :aria-expanded="open"
             @click="open = !open"
             @keydown.enter="open = !open"
             @keydown.space.prevent="open = !open">
          <h2 class="post-title">{{ post.title }}</h2>
          <span class="post-meta">{{ post.date.strftime('%d %b %Y') }}</span>
        </div>
        <p class="htmx-indicator" id="{{ post.slug }}-loading" aria-live="polite">Loading…</p>
        <div class="post-body" x-show="open" x-cloak></div>
      </div>
      {% endfor %}
    </main>
    {% if config.base_path.strip('/') %}
    <footer>
      <a href="{{ config.parent_url }}">← {{ config.parent_url.split('//')[-1].rstrip('/') }}</a>
    </footer>
    {% endif %}
  </div>
</body>
</html>
